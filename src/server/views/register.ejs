<%
const content = `
  ${ error ? '<div class="error">' + error + '</div>' : '' }
  ${ success ? '<div class="success">' + success + '</div>' : '' }
  <form method="POST" action="${registerUrl}">
    <label for="name">Full Name</label>
    <input type="text" id="name" name="name" required autofocus>
    <label for="email">Email</label>
    <input type="email" id="email" name="email" required>
    <label for="password">Password</label>
    <input type="password" id="password" name="password" required minlength="6">
    <input type="hidden" id="timezone" name="timezone" value="">
    <button type="submit" style="width:100%;">Create Account</button>
  </form>
  <p class="alt-link">Already have an account? <a href="${loginUrl}">Sign in</a></p>
`;
const scripts = '<script>try { document.getElementById("timezone").value = Intl.DateTimeFormat().resolvedOptions().timeZone; } catch(e) {}</script>';
%>
<%- include('_auth-layout', { title: 'Create Account — Mob CRM', subtitle: 'Create your account', content, scripts }) %>
