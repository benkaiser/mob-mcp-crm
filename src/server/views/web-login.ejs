<%
const redirectValue = (typeof redirect !== 'undefined' && redirect) ? redirect : '';
const escapedRedirect = redirectValue.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
const content = `
  ${ error ? '<div class="error">' + error + '</div>' : '' }
  <form method="POST" action="/web/login">
    <input type="hidden" name="redirect" value="${escapedRedirect}">
    <label for="email">Email</label>
    <input type="email" id="email" name="email" required autofocus>
    <label for="password">Password</label>
    <input type="password" id="password" name="password" required>
    <button type="submit" style="width:100%;">Sign In</button>
  </form>
  <p class="alt-link">Don't have an account? <a href="/auth/register?from=web">Create one</a></p>
`;
%>
<%- include('_auth-layout', { title: 'Sign In — Mob CRM', subtitle: 'Sign in to the dashboard', content }) %>
